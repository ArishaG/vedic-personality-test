# Copy this file to ".env.local" for local development with `vercel dev`.
# In production you set these in the Vercel dashboard (Settings -> Environment Variables).

# The single password that unlocks the Facilitator dashboard.
ADMIN_PASSWORD=change-this-password

# POSTGRES_URL is added automatically by Vercel when you connect a Postgres
# database to the project. You do not normally set it by hand.
# POSTGRES_URL=postgres://...

# Optional: live Google Sheets backup. Every submission is appended as a row
# to this sheet in addition to being saved in Postgres. Leave unset to disable.
# See DEPLOY.md "Optional: live Excel backup via Google Sheets" for setup steps.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEET_ID=the-id-from-your-sheet-url
# GOOGLE_SHEET_RANGE=Sheet1!A1
